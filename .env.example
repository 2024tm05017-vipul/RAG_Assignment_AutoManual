"""Environment template - copy to .env and configure"""

# Model Configuration
HF_HOME=/home/codespace/.cache/huggingface
HF_TOKEN=

# API Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=False

# Logging
LOG_LEVEL=INFO

# LLM Configuration
LLM_MODEL=microsoft/phi-2
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.3

# Embedding Configuration
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Feature Flags
USE_VISION_MODEL=True
USE_4BIT_QUANTIZATION=True
